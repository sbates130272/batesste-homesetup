  Avahi service definition for the AMD GPU metrics
  exporter. Copy to /etc/avahi/services/ on any machine
  running the exporter.
-->
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">%h amd-gpu-exporter</name>
  <service>
    <type>_amd-gpu-exporter._tcp</type>
    <port>5000</port>
  </service>
</service-group>
