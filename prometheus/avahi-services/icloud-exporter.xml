  Avahi service definition for the iCloud metrics exporter.
  Copy to /etc/avahi/services/ on the machine running
  the exporter.
-->
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">%h icloud-exporter</name>
  <service>
    <type>_icloud-exporter._tcp</type>
    <port>9948</port>
  </service>
</service-group>
