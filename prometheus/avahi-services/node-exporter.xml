  Avahi service definition for prometheus-node-exporter.
  Copy to /etc/avahi/services/ on each target machine.
  The %h token is replaced with the local hostname.
-->
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">%h node-exporter</name>
  <service>
    <type>_node-exporter._tcp</type>
    <port>9100</port>
  </service>
</service-group>
