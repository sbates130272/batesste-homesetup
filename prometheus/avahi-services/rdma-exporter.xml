  Avahi service definition for the RDMA exporter.
  Copy to /etc/avahi/services/ on any machine running
  the exporter.
-->
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">%h rdma-exporter</name>
  <service>
    <type>_rdma-exporter._tcp</type>
    <port>9879</port>
  </service>
</service-group>
