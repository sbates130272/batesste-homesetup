  Avahi service definition for the OpenAI usage exporter.
  Copy to /etc/avahi/services/ on the machine running
  the exporter.
-->
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">%h openai-exporter</name>
  <service>
    <type>_openai-exporter._tcp</type>
    <port>9185</port>
  </service>
</service-group>
