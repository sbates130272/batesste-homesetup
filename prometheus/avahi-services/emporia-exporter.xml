  Avahi service definition for the Emporia smart device
  exporter. Copy to /etc/avahi/services/ on the machine
  running the exporter.
-->
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">%h emporia-exporter</name>
  <service>
    <type>_emporia-exporter._tcp</type>
    <port>9947</port>
  </service>
</service-group>
