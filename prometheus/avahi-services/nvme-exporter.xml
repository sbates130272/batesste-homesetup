  Avahi service definition for the NVMe exporter.
  Copy to /etc/avahi/services/ on any machine running
  the exporter.
-->
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">%h nvme-exporter</name>
  <service>
    <type>_nvme-exporter._tcp</type>
    <port>9998</port>
  </service>
</service-group>
