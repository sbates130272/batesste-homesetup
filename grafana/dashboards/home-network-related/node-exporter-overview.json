        {
          "datasource": {
            "type": "prometheus",
            "uid": "ae8pyuqoyonpca"
          },
          "exemplar": true,
          "expr": "max(rate(node_disk_written_bytes_total{job=~\"$job\"}[$__rate_interval])) by (instance)",
