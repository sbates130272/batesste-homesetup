          "refId": "J"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "ae8pyuqoyonpca"
          },
          "exemplar": true,
          "expr": "max(rate(node_network_receive_bytes_total{job=~\"$job\"}[$__rate_interval])*8) by (instance)",
          "format": "table",
          "instant": true,
          "interval": "1m",
          "legendFormat": "",
          "refId": "K"
        },
        {
          "datasource": {
