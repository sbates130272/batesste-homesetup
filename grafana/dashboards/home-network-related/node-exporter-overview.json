            "uid": "ae8pyuqoyonpca"
          },
          "exemplar": true,
          "expr": "(1 - avg(rate(node_cpu_seconds_total{job=~\"$job\",mode=\"idle\"}[$__rate_interval])) by (instance)) * 100",
