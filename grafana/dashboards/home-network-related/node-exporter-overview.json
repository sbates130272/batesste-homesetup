          "instant": true,
          "interval": "1m",
          "legendFormat": "",
          "refId": "H"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "ae8pyuqoyonpca"
          },
          "expr": "node_netstat_Tcp_CurrEstab{job=~\"$job\"} - 0",
