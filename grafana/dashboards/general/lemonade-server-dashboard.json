      "targets": [
        {
          "expr": "snoc_pinewood_plug_h_power and lemonade_server_up{node=\"snoc-strix\"} * 0 + 1 == lemonade_server_up{node=\"$node\"} * 0 + 1 or snoc_pinewood_plug_d_power and lemonade_server_up{node=\"snoc-thinkstation\"} * 0 + 1 == lemonade_server_up{node=\"$node\"} * 0 + 1",
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
