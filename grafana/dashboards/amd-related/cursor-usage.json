{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Cursor IDE usage metrics from cursor-exporter",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "links": [],
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Subscription Overview (Session Mode)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Membership Type",
      "gridPos": { "h": 3, "w": 6, "x": 0, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "cursor_subscription_info",
          "legendFormat": "{{membership_type}}",
          "refId": "A",
          "instant": true,
          "format": "time_series",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Team Member",
      "gridPos": { "h": 3, "w": 6, "x": 6, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "cursor_subscription_team_member",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "time_series",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "No",
                  "color": "text",
                  "index": 0
                },
                "1": {
                  "text": "Yes",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Auto-Billing",
      "gridPos": { "h": 3, "w": 6, "x": 12, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "cursor_subscription_billable_auto",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "time_series",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "No",
                  "color": "text",
                  "index": 0
                },
                "1": {
                  "text": "Yes",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Payment Failed",
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "cursor_subscription_last_payment_failed",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "time_series",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "No",
                  "color": "green",
                  "index": 0
                },
                "1": {
                  "text": "Yes",
                  "color": "red",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "id": 6,
      "title": "Model Request Quotas (Session Mode)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "panels": []
    },
    {
      "type": "bargauge",
      "id": 7,
      "title": "Quota Usage %",
      "description": "Percentage of request quota used per model",
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 5 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "cursor_model_requests{model=~\"$model\"} / cursor_model_requests_max{model=~\"$model\"} * 100",
          "legendFormat": "{{model}}",
          "refId": "A",
          "instant": true,
          "format": "time_series",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16,
        "valueMode": "text"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "table",
      "id": 8,
      "title": "Model Breakdown",
      "gridPos": { "h": 8, "w": 14, "x": 10, "y": 5 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "cursor_model_requests{model=~\"$model\"}",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "cursor_model_requests_total{model=~\"$model\"}",
          "legendFormat": "",
          "refId": "B",
          "instant": true,
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "cursor_model_requests_max{model=~\"$model\"}",
          "legendFormat": "",
          "refId": "C",
          "instant": true,
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "cursor_model_tokens{model=~\"$model\"}",
          "legendFormat": "",
          "refId": "D",
          "instant": true,
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true
            },
            "indexByName": {
              "model": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4
            },
            "renameByName": {
              "model": "Model",
              "Value #A": "Requests",
              "Value #B": "Total Requests",
              "Value #C": "Quota",
              "Value #D": "Tokens"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Requests"
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "Token Consumption Over Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "cursor_model_tokens{model=~\"$model\"}",
          "legendFormat": "{{model}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "id": 10,
      "title": "Usage Events (Session Mode)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "panels": []
    },
    {
      "type": "stat",
      "id": 11,
      "title": "Total Cost",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 22 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(cursor_usage_events_cost_dollars{model=~\"$model\", kind=~\"$kind\"})",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "time_series",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 12,
      "title": "Total Requests",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 26 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(cursor_usage_events_request_count{model=~\"$model\", kind=~\"$kind\"})",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "time_series",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "piechart",
      "id": 13,
      "title": "Cost by Model",
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 22 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (model) (cursor_usage_events_cost_dollars{model=~\"$model\", kind=~\"$kind\"})",
          "legendFormat": "{{model}}",
          "refId": "A",
          "instant": true,
          "format": "time_series",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      }
    },
    {
      "type": "piechart",
      "id": 14,
      "title": "Cost by Kind",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 22 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (kind) (cursor_usage_events_cost_dollars{model=~\"$model\", kind=~\"$kind\"})",
          "legendFormat": "{{kind}}",
          "refId": "A",
          "instant": true,
          "format": "time_series",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      }
    },
    {
      "type": "barchart",
      "id": 15,
      "title": "Token Breakdown by Model",
      "description": "Input, output, and cache read tokens per model",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (model) (cursor_usage_events_input_tokens{model=~\"$model\", kind=~\"$kind\"})",
          "legendFormat": "Input \u2014 {{model}}",
          "refId": "A",
          "instant": true,
          "format": "time_series",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "sum by (model) (cursor_usage_events_output_tokens{model=~\"$model\", kind=~\"$kind\"})",
          "legendFormat": "Output \u2014 {{model}}",
          "refId": "B",
          "instant": true,
          "format": "time_series",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "sum by (model) (cursor_usage_events_cache_read_tokens{model=~\"$model\", kind=~\"$kind\"})",
          "legendFormat": "Cache Read \u2014 {{model}}",
          "refId": "C",
          "instant": true,
          "format": "time_series",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "options": {
        "orientation": "horizontal",
        "stacking": "normal",
        "showValue": "auto",
        "barWidth": 0.8,
        "groupWidth": 0.7,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "id": 16,
      "title": "Request Count Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (model) (cursor_usage_events_request_count{model=~\"$model\", kind=~\"$kind\"})",
          "legendFormat": "{{model}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          }
        },
        "overrides": []
      }
    },
    {
      "type": "table",
      "id": 17,
      "title": "Usage Events Detail",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 38 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "cursor_usage_events_cost_dollars{model=~\"$model\", kind=~\"$kind\"}",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "cursor_usage_events_input_tokens{model=~\"$model\", kind=~\"$kind\"}",
          "legendFormat": "",
          "refId": "B",
          "instant": true,
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "cursor_usage_events_output_tokens{model=~\"$model\", kind=~\"$kind\"}",
          "legendFormat": "",
          "refId": "C",
          "instant": true,
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "cursor_usage_events_cache_read_tokens{model=~\"$model\", kind=~\"$kind\"}",
          "legendFormat": "",
          "refId": "D",
          "instant": true,
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "cursor_usage_events_total_tokens{model=~\"$model\", kind=~\"$kind\"}",
          "legendFormat": "",
          "refId": "E",
          "instant": true,
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "cursor_usage_events_request_count{model=~\"$model\", kind=~\"$kind\"}",
          "legendFormat": "",
          "refId": "F",
          "instant": true,
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "model": 0,
              "kind": 1,
              "Value #A": 2,
              "Value #B": 3,
              "Value #C": 4,
              "Value #D": 5,
              "Value #E": 6,
              "Value #F": 7
            },
            "renameByName": {
              "model": "Model",
              "kind": "Kind",
              "Value #A": "Cost ($)",
              "Value #B": "Input Tokens",
              "Value #C": "Output Tokens",
              "Value #D": "Cache Read",
              "Value #E": "Total Tokens",
              "Value #F": "Requests"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Cost ($)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 4
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Cost ($)"
          }
        ]
      }
    },
    {
      "type": "row",
      "id": 18,
      "title": "Agent Edits (Enterprise / API Key Mode)",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "panels": [
        {
          "type": "stat",
          "id": 19,
          "title": "Total Suggested Diffs",
          "gridPos": { "h": 4, "w": 6, "x": 0, "y": 47 },
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "targets": [
            {
              "expr": "sum(cursor_agent_edits_suggested_diffs_total{team_id=~\"$team_id\"})",
              "legendFormat": "",
              "refId": "A",
              "instant": true,
              "format": "time_series",
              "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
