    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "The model of the AMD GPU detected on the remote server for the GPU ID selected.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "footer": {
              "reducers": []
            },
            "hideFrom": {
              "viz": false
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "custom.hideFrom.viz",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/^(gpu_id|card_model|card_vendor|hostname|instance|job|__name__|cluster_name|server_name|driver_version|gpu_compute_partition_type|gpu_memory_partition_type|gpu_partition_id|gpu_uuid|vbios_version)$/"
            },
            "properties": [
              {
                "id": "custom.hideFrom.viz",
                "value": true
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "options": {
        "cellHeight": "sm",
        "showHeader": false,
        "sortBy": []
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "amd_gpu_average_package_power{gpu_id=\"$gpu_id\",server_name=\"$hostname\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "GPU Model",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "card_model": true,
              "card_vendor": true,
              "gpu_id": true,
              "hostname": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "card_series": 0
            }
          }
        }
      ],
      "type": "table"
    },
